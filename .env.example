# ─── Database ───────────────────────────────────────────────
# Pooled connection for application queries (Neon pooler in prod, direct in local dev)
DATABASE_URL=postgresql://cadverify:localdev@postgres:5432/cadverify
# Direct connection for Alembic migrations (bypasses PgBouncer)
DATABASE_URL_DIRECT=postgresql://cadverify:localdev@postgres:5432/cadverify
POSTGRES_PASSWORD=localdev

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Backend API ────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=100
LOG_LEVEL=INFO
SAM3D_ENABLED=false
ANALYSIS_TIMEOUT_SEC=30
ACCEPTING_NEW_ANALYSES=true

# ─── Auth ───────────────────────────────────────────────────
SESSION_SECRET=change-me-in-production
HMAC_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=

# ─── Observability ──────────────────────────────────────────
SENTRY_DSN=
RELEASE=dev

# ─── Blob Storage ──────────────────────────────────────────
BLOB_STORAGE_PATH=/data/blobs

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_TURNSTILE_SITEKEY=1x00000000000000000000AA
