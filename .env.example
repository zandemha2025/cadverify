# ─── Database ───────────────────────────────────────────────
# Pooled connection for application queries (Neon pooler in prod, direct in local dev)
DATABASE_URL=postgresql://cadverify:localdev@postgres:5432/cadverify
# Direct connection for Alembic migrations (bypasses PgBouncer)
DATABASE_URL_DIRECT=postgresql://cadverify:localdev@postgres:5432/cadverify
POSTGRES_PASSWORD=localdev

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Backend API ────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=100
LOG_LEVEL=INFO
SAM3D_ENABLED=false
ANALYSIS_TIMEOUT_SEC=30
ACCEPTING_NEW_ANALYSES=true
RATE_LIBRARY_ENABLED=1
NEXT_PUBLIC_VERIFY_UI=1

# ─── Auth ───────────────────────────────────────────────────
# In production (RELEASE set to a real version) the backend refuses to start if
# SESSION_SECRET is unset or 'dev-only', or if AUTH_MODE uses Google and the
# GOOGLE_CLIENT_ID/SECRET are still 'dummy'. See main.py:_assert_production_secrets.
SESSION_SECRET=change-me-in-production
HMAC_SECRET=change-me-in-production
# API_KEY_PEPPER, DASHBOARD_SESSION_SECRET, MAGIC_LINK_SECRET, and
# AUTH_PROXY_SECRET must each be a
# base64-encoded value that decodes to >= 32 bytes. Generate with:
#   python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
API_KEY_PEPPER=
DASHBOARD_SESSION_SECRET=
MAGIC_LINK_SECRET=
AUTH_PROXY_SECRET=
AUTH_MODE=password
PASSWORD_LOGIN_ENABLED=1
MAGIC_LINK_ENABLED=1
PUBLIC_PASSWORD_SIGNUP_ENABLED=1
SECRET_ENFORCEMENT_ENABLED=1
WEBHOOK_SSRF_GUARD_ENABLED=1
RECONSTRUCTION_BACKEND=local
RECONSTRUCTION_ALLOW_REMOTE_EGRESS=0
# Remote mode additionally requires a reviewed, immutable Replicate model
# version and token. Never use a mutable owner/model slug in a release.
# TRIPOSR_REPLICATE_MODEL=owner/model:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# REPLICATE_API_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
RESEND_FROM=
PILOT_INBOX=
DASHBOARD_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:8000
TURNSTILE_SECRET=

# ─── Observability ──────────────────────────────────────────
SENTRY_DSN=
RELEASE=dev

# ─── Blob Storage ──────────────────────────────────────────
BLOB_STORAGE_PATH=/data/blobs
DESIGN_BLOB_DIR=/data/blobs/designs
DESIGN_GENERATION_TIMEOUT_SECONDS=45
DESIGN_GENERATION_CONCURRENCY=2

# ─── Frontend ──────────────────────────────────────────────
API_BASE=http://localhost:8000
NEXT_PUBLIC_VERIFY_UI=1
NEXT_PUBLIC_SHOW_DEV_TOOLS=1
MAGIC_LINK_UI_ENABLED=1
SSO_LOGIN_PATH=
TURNSTILE_SITE_KEY=1x00000000000000000000AA
