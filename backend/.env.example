# CADVerify backend configuration

# Comma-separated list of allowed CORS origins.
# Browsers ignore wildcard + credentials, so credentials are always disabled.
ALLOWED_ORIGINS=http://localhost:3000

# Maximum uploaded file size in megabytes. Requests exceeding this return 413.
MAX_UPLOAD_MB=100

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# ── SAM-3D Async Segmentation ──────────────────────────
# Set SAM3D_ENABLED=true on worker machines to activate SAM-3D processing
SAM3D_ENABLED=false
SAM3D_MODEL_PATH=/app/models/sam2_hiera_small.pt
SAM3D_CACHE_DIR=/data/blobs/sam3d_cache

# ── Job Queue (arq + Redis) ──────────────────────────
# REDIS_URL is also used by rate limiting (Phase 2)
# REDIS_URL=redis://localhost:6379
MESH_BLOB_DIR=/data/blobs/meshes
