# CADVerify backend configuration

# Comma-separated list of allowed CORS origins.
# Browsers ignore wildcard + credentials, so credentials are always disabled.
ALLOWED_ORIGINS=http://localhost:3000

# Maximum uploaded file size in megabytes. Requests exceeding this return 413.
MAX_UPLOAD_MB=100

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# ── SAM-3D Async Segmentation ──────────────────────────
# Set SAM3D_ENABLED=true on worker machines to activate SAM-3D processing
SAM3D_ENABLED=false
SAM3D_MODEL_PATH=/app/models/sam2_hiera_small.pt
SAM3D_CACHE_DIR=/data/blobs/sam3d_cache

# ── Job Queue (arq + Redis) ──────────────────────────
# REDIS_URL is also used by rate limiting (Phase 2)
# REDIS_URL=redis://localhost:6379
MESH_BLOB_DIR=/data/blobs/meshes

# ── Auth secrets ──────────────────────────────────────
# Each must be base64 that decodes to >= 32 bytes. Generate with:
#   python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
# In production (RELEASE set) startup fails closed when SESSION_SECRET is unset
# or 'dev-only' (and, under Google auth, when GOOGLE_CLIENT_ID/SECRET are 'dummy').
API_KEY_PEPPER=
DASHBOARD_SESSION_SECRET=
MAGIC_LINK_SECRET=
SESSION_SECRET=dev-only

# ── SSO auth mode ──────────────────────────────────────
# password | google | saml | oidc | hybrid  (default: google)
# 'hybrid' mounts password + google + magic-link + saml + oidc together.
AUTH_MODE=google

# ── OpenID Connect RP (Okta / Entra / Ping) ────────────
# Enterprise OIDC SSO, Authorization Code + PKCE (S256). Users land in the SAME
# session/org/group model as SAML; group→role assignment reuses the per-org
# SAML group mappings (attribute name = OIDC_GROUPS_CLAIM). Active when
# AUTH_MODE is 'oidc' or 'hybrid'.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Optional overrides (sensible defaults derived from OIDC_ISSUER / DASHBOARD_ORIGIN):
# OIDC_DISCOVERY_URL=${OIDC_ISSUER}/.well-known/openid-configuration
# OIDC_REDIRECT_URI=https://api.cadverify.com/auth/oidc/callback
# OIDC_SCOPES=openid email profile groups
# OIDC_GROUPS_CLAIM=groups
