# Public API base URL for the CadVerify backend.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Phase 2 (auth) — browser-visible
# Set in Vercel dashboard for production/preview environments.
NEXT_PUBLIC_API_BASE=https://api.cadverify.com
NEXT_PUBLIC_TURNSTILE_SITEKEY=1x00000000000000000000AA

# Phase 2 (auth) — server-only
# Set in Vercel dashboard (not exposed to browser).
API_BASE=https://api.cadverify.com

# Phase 6 (observability) — Sentry
# Set SENTRY_DSN and SENTRY_AUTH_TOKEN in Vercel dashboard.
# NEXT_PUBLIC_SENTRY_DSN is browser-visible; SENTRY_AUTH_TOKEN is server-only (source-map upload).
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Release tagging (set automatically by Vercel/CI — do not set manually)
SENTRY_RELEASE=
