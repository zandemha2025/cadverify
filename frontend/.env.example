# Backend origin used by server actions.
API_BASE=http://localhost:8000
AUTH_MODE=password
# Set only for SAML/OIDC deployments; the Helm SAML baseline derives this.
SSO_LOGIN_PATH=

# Runtime auth configuration. TURNSTILE_SITE_KEY is intentionally public but
# remains runtime-injected so one immutable image can promote across environments.
MAGIC_LINK_UI_ENABLED=1
PUBLIC_PASSWORD_SIGNUP_ENABLED=1
TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Shared server-only HMAC secret used to forward real client IPs to the API.
AUTH_PROXY_SECRET=

# Phase 6 (observability) — Sentry
# Set SENTRY_DSN and SENTRY_AUTH_TOKEN in Vercel dashboard.
# NEXT_PUBLIC_SENTRY_DSN is browser-visible; SENTRY_AUTH_TOKEN is server-only (source-map upload).
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Release tagging (set automatically by Vercel/CI — do not set manually)
NEXT_PUBLIC_SENTRY_RELEASE=dev
