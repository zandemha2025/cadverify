{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test $(find src -name '*.test.ts' -print | sort)",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "test:e2e:human": "node ../scripts/e2e/human-e2e-runner.mjs",
    "test:e2e:design-studio": "node ../scripts/e2e/design-studio-human-e2e.mjs",
    "test:e2e:site-design": "node ../scripts/e2e/site-design-fidelity.mjs",
    "test:e2e:enterprise": "node ../scripts/e2e/enterprise-domain-runner.mjs",
    "test:e2e:p7": "node ../scripts/e2e/p7-role-failure-journey-runner.mjs",
    "test:e2e:release-evidence": "node --test ../scripts/e2e/human-sim-release-evidence.test.mjs",
    "test:e2e:journey-coverage": "node ../scripts/e2e/human-sim-journey-coverage.mjs",
    "test:e2e:enterprise-gauntlet": "node ../scripts/e2e/synthetic-enterprise-gauntlet.mjs",
    "test:e2e:answer-fidelity": "node ../scripts/e2e/enterprise-answer-fidelity.mjs",
    "test:e2e:assembly-fidelity": "node ../scripts/e2e/assembly-visual-fidelity.mjs",
    "test:e2e:enterprise-presence": "node ../scripts/e2e/enterprise-systems-presence.mjs",
    "test:e2e:scim-idp": "node ../scripts/e2e/scim-idp-lifecycle.mjs",
    "test:e2e:connector-fixtures": "node ../scripts/e2e/connector-sandbox-fixture-replay.mjs",
    "test:e2e:real-cad-corpus": "sh -c 'if [ -x ../backend/.venv/bin/python ]; then ../backend/.venv/bin/python ../scripts/prehuman/real_cad_corpus.py; else python3 ../scripts/prehuman/real_cad_corpus.py; fi'",
    "test:e2e:ops-restore": "DATABASE_URL=${DATABASE_URL:-postgresql://cadverify:localdev@127.0.0.1:5432/cadverify} bash ../scripts/ops/postgres-restore-drill.sh",
    "test:e2e:ops-load": "node ../scripts/ops/api-load-smoke.mjs",
    "test:e2e:readiness": "node ../scripts/e2e/enterprise-prehuman-readiness.mjs",
    "test:e2e:training-guide": "node ../scripts/e2e/training-guide-e2e.mjs",
    "test:e2e:training-deck": "node ../scripts/e2e/training-deck-ui-e2e.mjs",
    "test:e2e:full": "npm run test:e2e:release-evidence && npm run test:e2e:human && npm run test:e2e:design-studio && npm run test:e2e:site-design && npm run test:e2e:enterprise && npm run test:e2e:p7 && npm run test:e2e:assembly-fidelity && npm run test:e2e:journey-coverage && npm run test:e2e:enterprise-gauntlet && npm run test:e2e:answer-fidelity && npm run test:e2e:enterprise-presence && npm run test:e2e:scim-idp && npm run test:e2e:connector-fixtures && npm run test:e2e:real-cad-corpus && npm run test:e2e:ops-restore && npm run test:e2e:ops-load && npm run test:e2e:readiness && npm run test:e2e:training-guide && npm run test:e2e:training-deck"
  },
  "dependencies": {
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "10.65.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/three": "^0.183.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
